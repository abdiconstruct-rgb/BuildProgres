<script>
  // ===== 1. FUNGSI WAKTU WIB =====
  const monthNamesShort = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
  function pad(n) { return n < 10 ? '0' + n : n; }
  function getTimeStr(d) { return `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`; }
  function formatDateShort(d) { return `${d.getDate()} ${monthNamesShort[d.getMonth()]} ${d.getFullYear()}`; }

  function getWIBNow() {
    const now = new Date();
    const utcMs = now.getTime() + (now.getTimezoneOffset() * 60000);
    return new Date(utcMs + (7 * 3600000));
  }
  function getWIBDateOnly() {
    const wib = getWIBNow();
    if (wib.getHours() === 0 && wib.getMinutes() === 0) {
      return new Date(wib.getFullYear(), wib.getMonth(), wib.getDate() - 1);
    }
    return new Date(wib.getFullYear(), wib.getMonth(), wib.getDate());
  }

  let lastKnownWIBDate = getWIBDateOnly().getTime();
  function updateClock() {
    const nowWIB = getWIBNow();
    const wibDateOnly = getWIBDateOnly();
    document.getElementById('liveClock').textContent = getTimeStr(nowWIB);
    document.getElementById('footerSync').textContent = `${formatDateShort(wibDateOnly)}, ${getTimeStr(nowWIB)} WIB`;
    
    const currentDateMs = wibDateOnly.getTime();
    if (currentDateMs !== lastKnownWIBDate) {
      lastKnownWIBDate = currentDateMs;
      location.reload();
    }
  }
  updateClock();
  setInterval(updateClock, 1000);

  // ===== 2. DATA DOKUMENTASI FOTO =====
  // Tambahkan atau ubah data array di bawah ini sesuai kebutuhan
  const documentationData = [
    {
      id: 1,
      category: "persiapan",
      title: "Bongkaran Area Lama",
      desc: "Pembongkaran struktur tidak terpakai",
      img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQdM2hPYzurMuelkWqSuMVRj1l9IoxVoEfmxIqKK0bLLw&s=10",
      link: "https://drive.google.com/drive/folders/1fJ94zslHBSC2PDB4blDDGal6_TFIv9aA?usp=sharing",
      date: "22 Jun 2026"
    },
    {
      id: 2,
      category: "persiapan",
      title: "Galian & Urug Tanah",
      desc: "Pekerdjaan tanah untuk persiapan pondasi",
      img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSzU0jDV0YjGwq7_DxavA8P7iet6cAhmsSA87VwFUS6Ig&s=10",
      link: "https://drive.google.com/drive/folders/1rvb_bogpHWWyTMpWy_uJ0RqvSi3tURhN?usp=sharing",
      date: "28 Jun 2026"
    },
    {
      id: 3,
