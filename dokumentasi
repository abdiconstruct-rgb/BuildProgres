      desc: "Pembuatan septic tank bawah tanah",
      img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRfrmXJM00tVO9qgIrbzVy4RpLn-o5c1b3uK0iBMY7Cjg&s",
      link: "https://drive.google.com/drive/folders/1m65shgSIZoNrlh1qBcLoPKsGdjjwtJsR?usp=drive_link",
      date: "02 Jul 2026"
    },
    {
      id: 4,
      category: "struktur",
      title: "Pondasi Tapak",
      desc: "Pengecoran pondasi tapak utama",
      img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcT4OixgJ9OUa59ukzyczxdmJ2PIgsG4i33mIvJrHGtxTg&s=10",
      link: "https://drive.google.com/drive/folders/1EnRBkTDffdtmWK0hYYC-smSu575kziEB?usp=drive_link",
      date: "10 Jul 2026"
    },
    {
      id: 5,
      category: "struktur",
      title: "Pondasi Slof",
      desc: "Pemasangan besi & cor slof pengikat",
      img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSY_cZT5TcnsIhr61d1jZoUKw4uOlB1Uq7q9WtW_zlSpg&s=10",
      link: "https://drive.google.com/drive/folders/1Bj9LykPdGdbsEd9D7P9tGiav9XaMe2jW?usp=drive_link",
      date: "18 Jul 2026"
    },
    {
      id: 6,
      category: "struktur",
      title: "Kolom Lantai 1",
      desc: "Pengecoran tiang bangunan lantai 1",
      img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQWf8aDYyua_qSEnsGU_aBt9_sjzj0Wl-CYlRPCe2IcRg&s=10",
      link: "https://drive.google.com/drive/folders/1sAVpBSWNGHdBaAl_fDKoAPNS6h1jULlQ?usp=drive_link",
      date: "26 Jul 2026"
    },
    {
      id: 7,
      category: "struktur",
      title: "Balok Lantai 2",
      desc: "Pemasangan besi & bekisting balok",
      img: "https://images.unsplash.com/photo-1581094794329-c8112a89af12?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60",
      link: "#",
      date: "05 Ags 2026"
    },
    {
      id: 8,
      category: "mep",
      title: "Instalasi Air Bersih",
      desc: "Pemasangan pipa air bersih lantai 1",
      img: "https://images.unsplash.com/photo-1585771724684-38269d6639fd?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60",
      link: "#",
      date: "12 Ags 2026"
    },
    {
      id: 9,
      category: "mep",
      title: "Instalasi Listrik",
      desc: "Pulling kabel MDP ke SDP lantai 1",
      img: "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60",
      link: "#",
      date: "18 Ags 2026"
    }
  ];

  // ===== 3. RENDER GALERI =====
  const galleryContainer = document.getElementById('photoGallery');
  
  function renderGallery(data) {
    galleryContainer.innerHTML = '';
    document.getElementById('totalPhotos').textContent = `Total: ${data.length} Dokumen`;

    if(data.length === 0) {
      galleryContainer.innerHTML = `
        <div class="col-span-full flex flex-col items-center justify-center py-20 text-center">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" class="mb-4"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <div class="text-[var(--muted)] text-[14px] font-semibold">Tidak Ada Dokumentasi</div>
          <div class="text-[var(--muted)] text-[12px] mt-1">Belum ada foto untuk kategori ini</div>
        </div>
      `;
      return;
    }

    data.forEach((item, index) => {
      const card = document.createElement("div");
      card.className = "photo-grid-item animate-item";
      card.style.animationDelay = `${index * 0.05}s`;
      card.setAttribute("data-category", item.category);
      
      card.innerHTML = `
        <img src="${item.img}" alt="${item.title}" loading="lazy">
        <div class="badge-top">${item.category}</div>
        <div class="badge-date">${item.date}</div>
        <a href="${item.link}" target="_blank" class="overlay">
          <div class="text-[14px] font-bold" style="color:var(--fg)">${item.title}</div>
          <div class="text-[11px] text-[var(--fg-dim)] mt-1">${item.desc}</div>
          <div class="flex items-center gap-1.5 mt-3 text-[10px] font-semibold text-[var(--accent)]">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
            LIHAT DRIVE
          </div>
        </a>
      `;
      galleryContainer.appendChild(card);
    });
  }

  // Inisialisasi render
  renderGallery(documentationData);

  // ===== 4. LOGIC FILTER =====
  function filterGallery(category) {
    // Update active state tombol pill
    const pills = document.querySelectorAll('.pill');
    pills.forEach(p => {
      p.classList.remove('pill-accent');
      // Tambah class accent ke pill yang sesuai
      if(p.textContent.toLowerCase().trim() === category || (category === 'all' && p.textContent.toLowerCase().trim() === 'semua')) {
        p.classList.add('pill-accent');
      }
    });

    // Filter data
    if(category === 'all') {
      renderGallery(documentationData);
    } else {
      const filteredData = documentationData.filter(item => item.category === category);
      renderGallery(filteredData);
    }
  }
